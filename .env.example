# Frontend environment variables (Vite). Copia este archivo a `.env` y completa.
# En Vercel se setean igual en Project Settings -> Environment Variables.

# Backend API URL
VITE_API_URL=http://localhost:4000/api

# Google Maps Embed API
VITE_GOOGLE_MAPS_KEY=

# Google OAuth — login de usuarios con Google
VITE_GOOGLE_CLIENT_ID=

# Sentry — error monitoring del frontend (opcional)
# Crea proyecto React en https://sentry.io y pega el DSN.
# Sin esto, Sentry queda apagado (no-op).
VITE_SENTRY_DSN=
