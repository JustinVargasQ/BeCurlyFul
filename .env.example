# Frontend environment variables (Vite) — Be Curly Full CR
# Copia este archivo a `.env` y completa. En Vercel se setean en Project Settings -> Environment Variables.

# Backend API URL
VITE_API_URL=http://localhost:4000/api

# Google Maps Embed API
VITE_GOOGLE_MAPS_KEY=

# Google OAuth — login de usuarios con Google
VITE_GOOGLE_CLIENT_ID=

# Sentry — error monitoring del frontend (opcional)
VITE_SENTRY_DSN=
